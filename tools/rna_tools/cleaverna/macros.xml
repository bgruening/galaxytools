<macros>
    <token name="@TOOL_VERSION@">1.0.0</token>
    <token name="@VERSION_SUFFIX@">0</token>
    <token name="@PROFILE@">21.01</token>
    <xml name="requirements">
        <requirements>
            <requirement type="package" version="1.0.0">cleaverna</requirement>
            <requirement type="package" version="8.32">coreutils</requirement>
        </requirements>
    </xml>
    <xml name="version_command">
        <version_command>cleaverna --help | head -1</version_command>
    </xml>
    <xml name="citations">
        <citations>
            <citation type="bibtex">
                @unpublished{cleaverna2026,
                    author = {Reyhaneh Tavakoli and contributors},
                    title = {CleaveRNA: Advanced machine learning-based computational tool for scoring candidate DNAzyme cleavage sites},
                    year = {2026},
                    url = {https://github.com/reyhaneh-tavakoli/CleaveRNA}
                }
            </citation>
        </citations>
    </xml>
    <xml name="param_LA">
        <param name="LA" type="integer" value="10" min="1" label="LA"/>
    </xml>
    <xml name="param_RA">
        <param name="RA" type="integer" value="10" min="1" label="RA"/>
    </xml>
    <xml name="param_CS">
        <param name="CS" type="select" multiple="true" display="checkboxes" label="Dinucleotides">
            <option value="AA">AA</option>
            <option value="AC" selected="true">AC</option>
            <option value="AG">AG</option>
            <option value="AU" selected="true">AU</option>
            <option value="CA">CA</option>
            <option value="CC">CC</option>
            <option value="CG">CG</option>
            <option value="CU">CU</option>
            <option value="GA">GA</option>
            <option value="GC" selected="true">GC</option>
            <option value="GG">GG</option>
            <option value="GU" selected="true">GU</option>
            <option value="UA">UA</option>
            <option value="UC">UC</option>
            <option value="UG">UG</option>
            <option value="UU">UU</option>
            <validator type="no_options" message="At least one cleavage site must be selected"/>
        </param>
    </xml>
    <xml name="param_Tem">
        <param name="Tem" type="float" value="37" label="Temperature (°C)"/>
    </xml>
    <xml name="param_CA">
        <param name="CA" type="text" label="Catalytic loop sequence (ATCG only)"/>
    </xml>
    <xml name="model_name">
        <param name="model_name" type="text" label="Model name"/>
    </xml>
    <xml name="target_files_prediction">
        <param name="target_files_prediction" type="data" format="fasta" multiple="true" label="Target FASTA files"/>
    </xml>
    <xml name="training_file_selector">
        <conditional name="training_file_source">
            <param name="training_file_method" type="select" label="Training file source">
                <option value="builtin">Use built‑in</option>
                <option value="upload">Upload CSV</option>
            </param>
            <when value="builtin">
                <param name="training_builtin" type="select" label="Select model">
                    <option value="HPBC_user_merged_num.csv">HPBC</option>
                    <option value="SARS_user_merged_num.csv">SARS</option>
                </param>
            </when>
            <when value="upload">
                <param name="training_upload" type="data" format="csv" label="Upload training CSV"/>
            </when>
        </conditional>
    </xml>
    <xml name="training_scores_selector">
        <conditional name="training_scores_source">
            <param name="scores_method" type="select" label="Training scores source">
                <option value="builtin">Use built‑in</option>
                <option value="upload">Upload CSV</option>
            </param>
            <when value="builtin">
                <param name="scores_builtin" type="select" label="Select scores">
                    <option value="HPBC_target.csv">HPBC scores</option>
                    <option value="SARS_target.csv">SARS scores</option>
                </param>
            </when>
            <when value="upload">
                <param name="scores_upload" type="data" format="csv" label="Upload scores CSV"/>
            </when>
        </conditional>
    </xml>
    <xml name="param_region">
        <param name="Start_End_Index" type="text" label="Target region (example: target.fasta:20-100)">
            <validator type="regex" message="Format: file:start-end">^.+:\d+-\d+$</validator>
        </param>
    </xml>
    <!-- PARAM SOURCE Default -->
    <xml name="params_selector">
        <conditional name="params_source">
            <param name="params_method" type="select" label="Parameter input method">
                <option value="manual">Create manually</option>
                <option value="csv">Upload CSV</option>
            </param>
            <when value="manual">
                <expand macro="param_LA"/>
                <expand macro="param_RA"/>
                <expand macro="param_CS"/>
                <expand macro="param_Tem"/>
                <expand macro="param_CA"/>
            </when>
            <when value="csv">
                <param name="params_csv" type="data" format="csv" label="Upload parameter CSV"/>
            </when>
        </conditional>
    </xml>
    <!-- PARAMS WITH REGION (target_check) -->
    <xml name="params_selector_region">
        <conditional name="params_source">
            <param name="params_method" type="select" label="Parameter input method">
                <option value="manual">Create manually</option>
                <option value="csv">Upload CSV</option>
            </param>
            <when value="manual">
                <repeat name="rows" title="Parameter rows" min="1">
                    <expand macro="param_LA"/>
                    <expand macro="param_RA"/>
                    <expand macro="param_CS"/>
                    <expand macro="param_region"/>
                    <expand macro="param_Tem"/>
                    <expand macro="param_CA"/>
                </repeat>
            </when>
            <when value="csv">
                <param name="params_csv" type="data" format="csv" label="Upload parameter CSV"/>
            </when>
        </conditional>
    </xml>
    <xml name="param_CS_index">
        <param name="CS_index" type="text" label="Cleavage site index (example: target_1.fasta:17-18)">
            <validator type="regex" message="Format must be: file:start-end">^.+:\d+-\d+$</validator>
        </param>
    </xml>
    <xml name="params_selector_screen">
        <conditional name="params_source">
            <param name="params_method" type="select" label="Parameter input method">
                <option value="manual">Create manually</option>
                <option value="csv">Upload CSV</option>
            </param>
            <when value="manual">
                <repeat name="rows" title="Parameter rows" min="1">
                    <expand macro="param_LA"/>
                    <expand macro="param_RA"/>
                    <expand macro="param_CS"/>
                    <expand macro="param_CS_index"/>
                    <expand macro="param_Tem"/>
                    <expand macro="param_CA"/>
                </repeat>
            </when>
            <when value="csv">
                <param name="params_csv" type="data" format="csv" label="Upload parameter CSV (columns: LA,RA,CS,CS_index,Tem,CA)"/>
            </when>
        </conditional>
    </xml>
    <xml name="param_LA_seq">
        <param name="LA_seq" type="text" label="Left arm sequence (LA_seq)">
            <validator type="regex" message="Sequence must contain only A,T,C,G">
            ^[ATCGatcg]+$
        </validator>
        </param>
    </xml>
    <xml name="param_RA_seq">
        <param name="RA_seq" type="text" label="Right arm sequence (RA_seq)">
            <validator type="regex" message="Sequence must contain only A,T,C,G">
            ^[ATCGatcg]+$
        </validator>
        </param>
    </xml>
    <xml name="param_CS_index_query">
        <param name="CS_Index_query" type="text" label="Cleavage site index (example: target_1.fasta:17-18)">
            <validator type="regex" message="Format must be filename:start-end">
            ^.+:\d+-\d+$
        </validator>
        </param>
    </xml>
    <xml name="params_selector_specific_query">
        <conditional name="params_source">
            <param name="params_method" type="select" label="Parameter input method">
                <option value="manual">Create manually</option>
                <option value="csv">Upload CSV</option>
            </param>
            <when value="manual">
                <repeat name="rows" title="Parameter rows" min="1">
                    <expand macro="param_LA_seq"/>
                    <expand macro="param_RA_seq"/>
                    <expand macro="param_CS"/>
                    <expand macro="param_CS_index_query"/>
                    <expand macro="param_Tem"/>
                    <expand macro="param_CA"/>
                </repeat>
            </when>
            <when value="csv">
                <param name="params_csv" type="data" format="csv" label="Upload parameter CSV (LA_seq,RA_seq,CS,CS_Index_query,Tem,CA)"/>
            </when>
        </conditional>
    </xml>
</macros>
