<macros>
    <token name="@TOOL_VERSION@">1.0.0</token>
    <token name="@VERSION_SUFFIX@">0</token>
    <token name="@PROFILE@">21.01</token>
    <xml name="requirements">
        <requirements>
            <requirement type="package" version="1.0.1">cleaverna</requirement>
        </requirements>
    </xml>
    <xml name="version_command">
        <version_command>cleaverna --help | head -1</version_command>
    </xml>
    <xml name="citations">
        <citations>
            <citation type="bibtex">
                @unpublished{cleaverna2026,
                    author = {Reyhaneh Tavakoli and contributors},
                    title = {CleaveRNA: Advanced machine learning-based computational tool for scoring candidate DNAzyme cleavage sites},
                    year = {2026},
                    url = {https://github.com/reyhaneh-tavakoli/CleaveRNA}
                }
            </citation>
        </citations>
    </xml>
    <xml name="model_name">
        <param name="model_name" type="text" label="Model name"/>
    </xml>
    <xml name="target_files_prediction">
        <param name="target_files_prediction" type="data" format="fasta" multiple="true" label="Target FASTA files"/>
    </xml>
    <xml name="training_file_selector">
        <conditional name="training_file_source">
            <param name="training_file_method" type="select" label="Training file source">
                <option value="builtin">Use built‑in</option>
                <option value="upload">Upload ZIP (containing CSV)</option>
            </param>
            <when value="builtin">
                <param name="training_builtin" type="select" label="Select model">
                    <option value="HPBC_user_merged_num.csv">HPBC</option>
                    <option value="SARS_user_merged_num.csv">SARS</option>
                </param>
            </when>
            <when value="upload">
                <param name="training_upload" type="data" format="zip" label="Upload training ZIP"/>
            </when>
        </conditional>
    </xml>
    <xml name="training_scores_selector">
        <conditional name="training_scores_source">
            <param name="scores_method" type="select" label="Training scores source">
                <option value="builtin">Use built‑in</option>
                <option value="upload">Upload CSV</option>
            </param>
            <when value="builtin">
                <param name="scores_builtin" type="select" label="Select scores">
                    <option value="HPBC_target.csv">HPBC scores</option>
                    <option value="SARS_target.csv">SARS scores</option>
                </param>
            </when>
            <when value="upload">
                <param name="scores_upload" type="data" format="csv" label="Upload scores CSV"/>
            </when>
        </conditional>
    </xml>
    <xml name="param_region">
        <param name="Start_End_Index" type="text" label="Target region (example: target.fasta:20-100)">
            <validator type="regex" message="Format: file:start-end">^.+:\d+-\d+$</validator>
        </param>
    </xml>
    <!-- PARAM SOURCE Default -->
    <xml name="params_selector">
        <param name="params_csv" type="data" format="csv" label="Upload parameter CSV"/>
    </xml>
    <!-- PARAMS WITH REGION (target_check) -->
    <xml name="params_selector_region">
        <param name="params_csv" type="data" format="csv" label="Upload parameter CSV"/>
    </xml>
    <xml name="params_selector_screen">
        <param name="params_csv" type="data" format="csv" label="Upload parameter CSV (columns: LA,RA,CS,CS_index,Tem,CA)"/>
    </xml>
    <xml name="params_selector_specific_query">
        <param name="params_csv" type="data" format="csv" label="Upload parameter CSV (LA_seq,RA_seq,CS,CS_Index_query,Tem,CA)"/>
    </xml>
</macros>
