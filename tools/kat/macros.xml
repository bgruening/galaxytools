<macros>
    <token name="@TOOL_VERSION@">2.4.2</token>
    <token name="@VERSION_SUFFIX@">0</token>
    <token name="@PROFILE@">25.0</token>
    <xml name="xrefs">
        <xrefs>
            <xref type="bio.tools">kat</xref>
        </xrefs>
    </xml>
    <xml name="requirements">
        <requirements>
            <!-- <requirement type="package" version="@TOOL_VERSION@">kat</requirement> -->
            <container type="docker">quay.io/galaxy/kat:v1.0</container> -->
        </requirements>
    </xml>
    <xml name="kmer_params">
        <section name="kmer_options" title="K-mer Options" expanded="false">
            <param argument="--mer_len" type="integer" value="27" min="1" max="64" label="K-mer length" help="The k-mer length to use. Larger values provide more discriminating power but require more memory and lower coverage."/>
            <param argument="--hash_size" type="integer" value="100000000" min="1" label="Hash size" help="Hash size for k-mer counting. If too small, it will be doubled automatically, increasing runtime and memory."/>
            <param argument="--non_canonical" type="boolean" truevalue="--non_canonical" falsevalue="" checked="false" label="Non-canonical k-mers" help="Store explicit k-mers as found. By default canonical k-mers are stored (both strands counted)."/>
            <yield/>
        </section>
    </xml>

    <!-- Cheetah token: maps $f.ext to $ext; use inside #for loops where the loop variable is $f -->
    <token name="@SET_EXT@"><![CDATA[
        #if $f.ext in ('fastq.gz', 'fastqsanger.gz'):
            #set $ext = '.fastq.gz'
        #elif $f.ext == 'fasta.gz':
            #set $ext = '.fasta.gz'
        #elif $f.ext in ('fastq', 'fastqsanger'):
            #set $ext = '.fastq'
        #elif $f.ext == 'jellyfish':
            #set $ext = '.jf'
        #else:
            #set $ext = '.fasta'
        #end if
    ]]></token>

    <!-- Cheetah token: only emits 5ptrim when the value is non-empty (kat_hist: $advanced_options.trim_5p) -->
    <token name="@CMD_5PTRIM@"><![CDATA[
        #if str($advanced_options.trim_5p).strip():
            --5ptrim '$advanced_options.trim_5p'
        #end if
    ]]></token>

    <xml name="five_prime_trim_param">
        <param argument="--5ptrim" name="five_prime_trim" type="text" value="" label="5' trim length" help="Ignore the first X bases from reads. For multiple input files, provide comma-separated values (e.g. 5,10,0). Leave blank to disable.">
            <validator type="regex" message="Must be empty, a number, or comma-separated numbers">^[0-9]+(,[0-9]+)*$|^$</validator>
        </param>
    </xml>

    <xml name="output_type_param">
        <param name="output_type" type="select" label="Plot file format" help="File format for the output plot.">
            <option value="png" selected="true">PNG</option>
            <option value="pdf">PDF</option>
        </param>
    </xml>
    
    <xml name="creator">
        <creator>
            <person givenName="Saim" familyName="Momin" url="https://github.com/SaimMomin12"/>
            <organization name="Galaxy Europe" url="https://galaxyproject.org/eu/"/>
        </creator>
    </xml>
    <xml name="citations">
        <citations>
            <citation type="doi">10.1093/bioinformatics/btw663</citation>
        </citations>
    </xml>
</macros>
