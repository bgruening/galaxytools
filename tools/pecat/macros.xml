<macros>
    <token name="@TOOL_VERSION@">0.0.3</token>
    <token name="@VERSION_SUFFIX@">0</token>
    <token name="@PROFILE@">25.0</token>
    <xml name="requirements">
        <requirements>
            <requirement type="package" version="@TOOL_VERSION@">pecat</requirement>
            <requirement type="package" version="1.5.0">racon</requirement>
        </requirements>
    </xml>
    <xml name="edam_ontology">
        <edam_topics>
            <edam_topic>topic_0196</edam_topic>
            <edam_topic>topic_0622</edam_topic>
        </edam_topics>
        <edam_operations>
            <edam_operation>operation_0525</edam_operation>
            <edam_operation>operation_3216</edam_operation>
        </edam_operations>
    </xml>
    <xml name="xrefs">
        <xrefs>
            <xref type="bio.tools">pecat</xref>
        </xrefs>
    </xml>
    <xml name="opts_sanitizer">
        <sanitizer>
            <valid initial="string.letters,string.digits">
                <add value=" "/>
                <add value="-"/>
                <add value="_"/>
                <add value="="/>
                <add value=":"/>
                <add value=","/>
                <add value="."/>
                <add value="|"/>
                <add value="/"/>
                <add value="&quot;"/>
            </valid>
        </sanitizer>
    </xml>
    <token name="@READS_EXT@">
        #if $reads_input.is_of_type('fasta.gz')
            #set $ext = '.fasta.gz'
        #elif $reads_input.is_of_type('fastqsanger.gz')
            #set $ext = '.fastq.gz'
        #elif $reads_input.is_of_type('fastqsanger')
            #set $ext = '.fastq'
        #else
            #set $ext = '.fasta'
        #end if
    </token>
    <xml name="prep_section" tokens="output_coverage">
        <section name="prep" title="Preparation" expanded="false">
            <param argument="prep_min_length" type="integer" value="3000" min="0" label="Minimum read length to keep" help="Reads shorter than this are filtered out before correction"/>
            <param argument="prep_output_coverage" type="integer" value="@OUTPUT_COVERAGE@" min="0" label="Target coverage after preparation" help="Reads are subsampled to this coverage of the estimated genome size before correction"/>
        </section>
    </xml>
    <xml name="corr_section" tokens="rd2rd_options,filter_options,correct_options,output_coverage">
        <section name="corr" title="Correction" expanded="false">
            <param argument="corr_iterate_number" type="integer" value="1" min="1" label="Number of correction iterations" help="How many rounds of error correction to run"/>
            <param argument="corr_block_size" type="integer" value="4000000000" min="1" label="Correction block size (bp)" help="Approximate block size used to split work for parallel correction"/>
            <param argument="corr_rd2rd_options" type="text" value="@RD2RD_OPTIONS@" label="minimap2 options for read-vs-read overlap (corr_rd2rd_options)" help="Passed to minimap2 during overlap detection in the correction stage">
                <expand macro="opts_sanitizer"/>
            </param>
            <param argument="corr_filter_options" type="text" value="@FILTER_OPTIONS@" label="Overlap filter options (corr_filter_options)" help="Filtering thresholds for raw overlaps used during correction">
                <expand macro="opts_sanitizer"/>
            </param>
            <param argument="corr_correct_options" type="text" value="@CORRECT_OPTIONS@" label="Correction options (corr_correct_options)" help="Aligner choice and scoring/filtering parameters for the correction step">
                <expand macro="opts_sanitizer"/>
            </param>
            <param argument="corr_output_coverage" type="integer" value="@OUTPUT_COVERAGE@" min="0" label="Target coverage of corrected reads" help="Corrected reads are subsampled to this coverage before assembly"/>
        </section>
    </xml>
    <xml name="align_section" tokens="rd2rd_options,filter_options">
        <section name="align" title="Alignment" expanded="false">
            <param argument="align_block_size" type="integer" value="4000000000" min="1" label="Alignment block size (bp)"/>
            <param argument="align_rd2rd_options" type="text" value="@RD2RD_OPTIONS@" label="minimap2 options for read-vs-read overlap (align_rd2rd_options)">
                <expand macro="opts_sanitizer"/>
            </param>
            <param argument="align_filter_options" type="text" value="@FILTER_OPTIONS@" label="Alignment filter options (align_filter_options)">
                <expand macro="opts_sanitizer"/>
            </param>
        </section>
    </xml>
    <xml name="asm1_section" tokens="assemble_options">
        <section name="asm1" title="First-round assembly" expanded="false">
            <param argument="asm1_assemble_options" type="text" value="@ASSEMBLE_OPTIONS@" label="First-round assembly options (asm1_assemble_options)">
                <expand macro="opts_sanitizer"/>
            </param>
        </section>
    </xml>
    <xml name="asm2_section" tokens="assemble_options">
        <section name="asm2" title="Second-round assembly" expanded="false">
            <param argument="asm2_assemble_options" type="text" value="@ASSEMBLE_OPTIONS@" label="Second-round assembly options (asm2_assemble_options)">
                <expand macro="opts_sanitizer"/>
            </param>
        </section>
    </xml>
    <xml name="phase_basic_params" tokens="rd2ctg_options,phase_options,filter_options,use_reads_1_selected">
        <param argument="phase_use_reads" type="select" label="Reads to use for phasing (phase_use_reads)">
            <option value="0">Raw reads</option>
            <option value="1" selected="@USE_READS_1_SELECTED@">Corrected reads</option>
        </param>
        <param argument="phase_rd2ctg_options" type="text" value="@RD2CTG_OPTIONS@" label="minimap2 options for read-to-contig mapping (phase_rd2ctg_options)">
            <expand macro="opts_sanitizer"/>
        </param>
        <param argument="phase_phase_options" type="text" value="@PHASE_OPTIONS@" label="Inconsistent overlap detection options (phase_phase_options)">
            <expand macro="opts_sanitizer"/>
        </param>
        <param argument="phase_filter_options" type="text" value="@FILTER_OPTIONS@" label="Phase filter options (phase_filter_options)">
            <expand macro="opts_sanitizer"/>
        </param>
    </xml>
    <xml name="polish_section" tokens="map_options,filter_options,use_reads_0_selected,use_reads_1_selected">
        <section name="polish" title="Polishing (Racon)" expanded="false">
            <param argument="polish_use_reads" type="select" label="Reads to use for Racon polishing (polish_use_reads)">
                <option value="0" selected="@USE_READS_0_SELECTED@">Raw reads</option>
                <option value="1" selected="@USE_READS_1_SELECTED@">Corrected reads</option>
            </param>
            <param argument="polish_map_options" type="text" value="@MAP_OPTIONS@" label="minimap2 options for assembly-to-reads mapping (polish_map_options)">
                <expand macro="opts_sanitizer"/>
            </param>
            <param argument="polish_filter_options" type="text" value="@FILTER_OPTIONS@" optional="true" label="Polish filter options (polish_filter_options)">
                <expand macro="opts_sanitizer"/>
            </param>
            <param argument="polish_cns_options" type="text" value="" optional="true" label="Racon options (polish_cns_options)">
                <expand macro="opts_sanitizer"/>
            </param>
        </section>
    </xml>
    <xml name="ont_params">
        <expand macro="prep_section" output_coverage="80"/>
        <expand macro="corr_section" rd2rd_options="-x ava-ont -k19" filter_options="--filter0=l=5000:al=2500:alr=0.5:aal=5000:oh=3000:ohr=0.3" correct_options="--score=weight:lc=10 --aligner edlib --filter1 oh=1000:ohr=0.01" output_coverage="80"/>
        <expand macro="align_section" rd2rd_options="-X -g3000 -w30 -k19 -m100 -r500 -f 0.001" filter_options="--filter0=l=5000:aal=6000:aalr=0.5:oh=3000:ohr=0.3 --task=extend --filter1=oh=300:ohr=0.03"/>
        <expand macro="asm1_section" assemble_options="--max_trivial_length 10000"/>
        <section name="phase" title="Phasing" expanded="false">
            <conditional name="phase_method_cond">
                <param argument="phase_method" type="select" label="Phasing method (phase_method)" help="0: PECAT's built-in FSA caller.">
                    <option value="0" selected="true">Built-in FSA caller</option>
                </param>
                <when value="0">
                    <expand macro="phase_basic_params" rd2ctg_options="-x map-ont -c -p 0.5 -r 1000" phase_options=" --coverage lc=30 --phase_options icr=0.1:icc=8:sc=10" filter_options=" --threshold=1000" use_reads_1_selected="true"/>
                </when>
            </conditional>
        </section>
        <expand macro="asm2_section" assemble_options="--max_trivial_length 10000 --contig_format dual,prialt"/>
        <expand macro="polish_section" map_options="-x map-ont -k19 -w10 -I 10g" filter_options="" use_reads_0_selected="true" use_reads_1_selected="false"/>
    </xml>
    <xml name="clr_params">
        <expand macro="prep_section" output_coverage="80"/>
        <expand macro="corr_section" rd2rd_options="-x ava-pb" filter_options="--filter0=:al=5000:alr=0.5:aal=8000:aalr=0.5:oh=2000:ohr=0.2" correct_options="--score=weight:lc=10 --aligner diff --filter1 oh=1000:ohr=0.01" output_coverage="80"/>
        <expand macro="align_section" rd2rd_options="-X -g3000 -w30 -k19 -m100 -r500" filter_options="--filter0=l=3000:al=3000:alr=0.5:aalr=0.5:oh=1000:ohr=0.1 --task=extend --filter1=oh=100:ohr=0.01"/>
        <expand macro="asm1_section" assemble_options="--max_trivial_length 10000"/>
        <section name="phase" title="Phasing" expanded="false">
            <conditional name="phase_method_cond">
                <param argument="phase_method" type="select" label="Phasing method (phase_method)" help="Only the built-in FSA caller is supported for PacBio CLR.">
                    <option value="0" selected="true">Built-in FSA caller</option>
                </param>
                <when value="0">
                    <expand macro="phase_basic_params" rd2ctg_options="-x map-pb -c -p 0.5 -r 1000" phase_options=" --phase_options icr=0.2" filter_options=" --threshold=1000" use_reads_1_selected="true"/>
                </when>
            </conditional>
        </section>
        <expand macro="asm2_section" assemble_options="--max_trivial_length 10000 --contig_format dual,prialt"/>
        <expand macro="polish_section" map_options="-x asm20" filter_options="" use_reads_0_selected="false" use_reads_1_selected="true"/>
    </xml>
    <xml name="hifi_params">
        <expand macro="prep_section" output_coverage="60"/>
        <expand macro="corr_section" rd2rd_options="-X -g3000 -w30 -k19 -m100 -r500 -f 0.002 -K8G -I 8G" filter_options="--filter0=l=5000:al=2500:alr=0.5:aal=5000:oh=3000:ohr=0.3" correct_options="--score=weight:lc=8 --aligner diff:s=100 --min_coverage 1 --filter1 oh=100 --min_identity 96 --min_local_identity 95" output_coverage="60"/>
        <expand macro="align_section" rd2rd_options="-X -g3000 -w30 -k19 -m100 -r500 -f 0.002 -K8G -I 8G" filter_options="--filter0=l=5000:aal=6000:aalr=0.5:oh=3000:ohr=0.3 --task=extend --filter1=oh=50:ohr=0.01 --aligner diff:s=100 --min_identity 0.90"/>
        <expand macro="asm1_section" assemble_options=" --min_identity 0.99 --min_coverage 1"/>
        <section name="phase" title="Phasing" expanded="false">
            <conditional name="phase_method_cond">
                <param argument="phase_method" type="select" label="Phasing method (phase_method)" help="0: built-in FSA caller.">
                    <option value="0" selected="true">Built-in FSA caller</option>
                </param>
                <when value="0">
                    <expand macro="phase_basic_params" rd2ctg_options="-x map-hifi -c -p 0.5 -r 1000 -K8G" phase_options=" --coverage lc=8 --phase_options icr=0.02:icc=3:sc=4 --filter=i=95.00:alr=0.80:oh=100:ohr=0.01:ilid=100" filter_options="" use_reads_1_selected="true"/>
                </when>
            </conditional>
        </section>
        <expand macro="asm2_section" assemble_options=" --reducer0 &quot;best:cmp=2,0.1,0.1|phase:sc=2&quot; --min_identity 0.99 --max_trivial_length 10000 --contig_format dual,prialt --min_coverage 1"/>
        <expand macro="polish_section" map_options="-x map-hifi -I8G -K8G -a" filter_options="--filter0 oh=500:ohr=0.05:i=98" use_reads_0_selected="false" use_reads_1_selected="true"/>
    </xml>
    <xml name="citations">
        <citations>
            <citation type="doi">10.5281/zenodo.8380113</citation>
            <citation type="doi">10.1101/2022.09.25.509436</citation>
        </citations>
    </xml>
    <xml name="creator">
        <creator>
            <organization name="Galaxy Europe"/>
            <person givenName="Saim" familyName="Momin" url="https://github.com/SaimMomin12"/>
        </creator>
    </xml>
</macros>
