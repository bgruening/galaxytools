<tool id="kraken_binarize" name="Kraken Binarize" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>binarise document images</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="requirements"/>
    <expand macro="creators"/>
    <command detect_errors="exit_code"><![CDATA[
        #set $output_format_flag = '-n' 
        @REJECT_MULTIPAGE_TIFF_BASED_ON_FILE_METADATA@
        @CREATE_SYMLINKS@
        @RUN_KRAKEN@ binarize
            --threshold '$threshold'
            --zoom '$zoom'
            --escale '$escale'
            --border '$border'
            --perc '$perc'
            --range '$range'
            --low '$low'
            --high '$high'
    ]]></command>
    <expand macro="env_vars"/>
    <inputs>
        <expand macro="input_param"/>
        <param name="out_ext" type="select" label="Output format">
            <option value="png" selected="true">png</option>
            <option value="tiff">tiff</option>
        </param>
        <!-- in kraken unbounded - tested manually: <0 output completely white; >0.999 output completely black. -->
        <param argument="--threshold" type="float" value="0.5" min="0" max="0.999" label="Threshold"/>
        <!-- in kraken unbounded - tested manually: <0.1 turning the right edge into a white line; >1 processing very slow. -->
        <param argument="--zoom" type="float" value="0.5" min="0.1" max="1.0" label="Zoom for background page estimation"/>
        <!-- in kraken unbounded - tested manually: <0.02 errors out; >10 processing very slow. -->
        <param argument="--escale" type="float" value="1.0" min="0.02" max="10.0" label="Scale estimate"/>
        <!-- in kraken unbounded - tested manually: <0 does not change anything; >0.499 errors out. -->
        <param argument="--border" type="float" value="0.1" min="0" max="0.499" label="Ignore this much of the border"/>
        <!-- in kraken bounded -->
        <param argument="--perc" type="integer" min="1" max="100" value="80" label="Percentage for filters"/>
        <!-- in kraken unbounded - tested manually: <1 errors out; >100 processing very slow. -->
        <param argument="--range" type="integer" value="20" min="1" max="100" label="Range for filters"/>
        <!-- both low/high are in kraken bounded -->
        <param argument="--low" type="integer" min="1" max="100" value="5" label="Percentile for black estimation"/>
        <param argument="--high" type="integer" min="1" max="100" value="90" label="Percentile for white estimation"/>
    </inputs>
    <outputs>
        <data name="output" format="png" label="${tool.name} on ${on_string}">
            <filter>image.ext != "pdf"</filter>
            <actions>
                <conditional name="out_ext">
                    <when value="png">
                        <action type="format" default="png"/>
                    </when>
                    <when value="tiff">
                        <action type="format" default="tiff"/>
                    </when>
                </conditional>
            </actions>
        </data>
        <collection name="pdf_output" type="list" label="${tool.name} pages on ${on_string}">
            <filter>image.ext == "pdf"</filter>
            <discover_datasets pattern="(?P&lt;designation&gt;.+)\.(?P&lt;ext&gt;png|tiff)"/>
        </collection>
    </outputs>
    <tests>
        <test expect_num_outputs="1">
            <param name="image" value="input.jpg" ftype="jpg"/>
            <output name="output" ftype="png">
                <expand macro="assert_binarized"/>
            </output>
        </test>
        <test expect_num_outputs="1">
            <param name="image" value="input.tiff" ftype="tiff"/>
            <output name="output" ftype="png">
                <expand macro="assert_binarized"/>
            </output>
        </test>
        <test expect_num_outputs="1">
            <param name="image" value="input_2pages.pdf" ftype="pdf"/>
            <output_collection name="pdf_output" type="list" count="2">
                <element name="input.pdf_000000" ftype="png">
                    <expand macro="assert_binarized_pdf"/>
                </element>
                <element name="input.pdf_000001" ftype="png">
                    <expand macro="assert_binarized_pdf"/>
                </element>
            </output_collection>
        </test>
        <test expect_failure="true">
            <param name="image" value="input_2pages.tiff" ftype="tiff"/>
            <assert_stderr>
                <has_text text="multi-page TIF(F) input is not supported"/>
                <has_text text="Detected 2 pages"/>
            </assert_stderr>
        </test>
    </tests>
    <help format="markdown">
**What it does**
        
Kraken is a powerful OCR system for all languages. 
This tool only exposes Kraken's binarization command.

Binarization converts the input image/document into a binary image 
suitable for downstream segmentation and OCR steps.

For PDF inputs, this tool returns a Galaxy list collection 
of PNG images, one for each page.

**License**

Kraken is licensed under the Apache-2.0 license.

**Algorithmic background**

kraken's ``binarize`` command is derived from OCRopus/ocropy's 
``nlbin``, a preprocessing script designed for degraded and 
historical book pages.
    </help>
    <expand macro="citations"/>
</tool>
