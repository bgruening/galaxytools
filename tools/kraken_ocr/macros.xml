<macros>
    <token name="@TOOL_VERSION@">7.0.2</token>
    <token name="@VERSION_SUFFIX@">0</token>
    <token name="@PROFILE@">25.1</token>
    <!-- Torch cache dir macro taken from tools/flexynesis -->
    <token name="@TORCH_TMP_DIR@"><![CDATA[
        export TORCHINDUCTOR_CACHE_DIR=\$_GALAXY_JOB_TMP_DIR &&
    ]]></token>
    <token name="@CREATE_SYMLINKS@"><![CDATA[
        ln -s '$image' 'input.${image.ext}' &&

        #if $image.ext != 'pdf'
            ln -s '$output' 'kraken_output.${out_ext}' &&
        #end if
    ]]></token>
    <token name="@REJECT_MULTIPAGE_TIFF_BASED_ON_FILE_METADATA@"><![CDATA[
        #if $image.ext in ("tiff", "tif")
            {
                pages=\$(tr -d '[] ' < '$image.metadata.offsets' | tr ',' '\n' | grep -c '[0-9]');

                if [ "\$pages" -gt 1 ]; then
                    echo "It seems like multi-page TIF(F) input is not supported by kraken 7. Detected \$pages pages. Please use PDF input or split it first." >&2;
                    exit 1;
                fi;
            } &&
        #end if
    ]]></token>
    <token name="@RUN_KRAKEN@"><![CDATA[
        kraken
            $format_type
            --raise-on-error

            #if $image.ext == 'pdf'
                -f pdf
                -I 'input.${image.ext}'
                -o .${out_ext}
            #else
                --input 'input.${image.ext}' 'kraken_output.${out_ext}'
            #end if
    ]]></token>
    <xml name="requirements">
        <requirements>
            <requirement type="package" version="@TOOL_VERSION@">kraken-ocr</requirement>
        </requirements>
    </xml>
    <xml name="creators">
        <creator>
            <!-- for me the ORCID somehow only renders with the full URL -->
            <person givenName="Ivo Christopher" familyName="Leist" email="leist@informatik.uni-freiburg.de" identifier="https://orcid.org/0000-0002-9772-443X"/>
            <organization name="AI4SOCIAL+" url="https://cordis.europa.eu/project/id/101292886"/>
        </creator>
    </xml>
    <xml name="citations">
        <citations>
            <citation type="bibtex">
                @article{Kiessling_2021,
                    title={Advances and Limitations in Open Source Arabic-Script OCR: A Case Study},
                    volume={11},
                    ISSN={1918-3666},
                    url={http://dx.doi.org/10.16995/dscn.8094},
                    DOI={10.16995/dscn.8094},
                    number={1},
                    journal={Digital Studies / Le champ numérique},
                    publisher={Open Library of the Humanities},
                    author={Kiessling, Benjamin and Kurin, Gennady and Miller, Matthew Thomas and Smail, Kader},
                    year={2021},
                    month=Dec }
            </citation>
        </citations>
    </xml>
    <macro name="input_param">
        <param name="image" type="data" format="jpg,png,tiff,pdf" label="Image or document" help="multipage is only supported for PDF inputs"/>
    </macro>
    <macro name="assert_binarized" token_width="1456" token_height="2184">
        <assert_contents>
            <has_image_channels channels="1"/>
            <has_image_width width="@WIDTH@"/>
            <has_image_height height="@HEIGHT@"/>
        </assert_contents>
    </macro>
    <macro name="assert_binarized_pdf">
        <expand macro="assert_binarized" width="1875" height="2812"/>
    </macro>
</macros>
