<tool id="webatlas_consolidate_md" name="Webatlas Consolidate Metadata" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" python_template_version="3.5" profile="@PROFILE_VERSION@">
    <description>TODO description</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="requirements"/>
    <command detect_errors="exit_code"><![CDATA[
        if tiffinfo $input_image | grep "Compression Scheme:" | grep -wq "JPEG";
        then
            if od -h -j2 -N2 $input_image | head -n1 | sed 's/[0-9]*  *//' | grep -q -E '002b|2b00';
            then
                tiffcp -c none -m 0 -8 $input_image uncompressed.tif;
            else
                tiffcp -c none -m 0 $input_image uncompressed.tif || tiffcp -c none -m 0 -8 $input_image uncompressed.tif;
            fi;
                bioformats2raw --no-hcs uncompressed.tif output.zarr;
        else
            bioformats2raw --no-hcs $input_image output.zarr;
        fi;
        /usr/local/bin/consolidate_md.py --file_in output.zarr &&
        zip -r output.zarr.zip output.zarr &&
        mv output.zarr.zip $output_zarr
    ]]></command>
    <inputs>
        <param name="input_image" type="data" format="tif,tiff,jpg" label="tiff or jpg image"/>
    </inputs>
    <outputs>
        <data name="output_zarr" format="zarr.zip" label="${tool.name} on ${on_string}: zarr output"/>
    </outputs>
    <tests>
    <test expect_num_outputs="1">
        <param name="input_image" location="https://zenodo.org/records/19053876/files/visium-breast-cancer-label.tif"/>
        <output name="output_zarr">
            <assert_contents>
                <has_archive_member path="output.zarr/.zattrs"/>
                <has_archive_member path="output.zarr/.zgroup"/>
                <has_archive_member path="output.zarr/.zmetadata"/>
                <has_archive_member path="output.zarr/0/.zattrs"/>
                <has_archive_member path="output.zarr/0/.zgroup"/>
                <has_archive_member path="output.zarr/OME/METADATA.ome.xml"/>
                <has_size value="6340177" delta="50000"/>
            </assert_contents>
        </output>
    </test>
    <test expect_num_outputs="1">
        <param name="input_image" location="https://zenodo.org/records/19053876/files/tissue_image.tif"/>
        <output name="output_zarr">
            <assert_contents>
                <has_archive_member path="output.zarr/.zattrs"/>
                <has_archive_member path="output.zarr/.zgroup"/>
                <has_archive_member path="output.zarr/.zmetadata"/>
                <has_archive_member path="output.zarr/0/.zattrs"/>
                <has_archive_member path="output.zarr/0/.zgroup"/>
                <has_archive_member path="output.zarr/OME/METADATA.ome.xml"/>
                <has_size value="1096196704" delta="100000"/>
            </assert_contents>
        </output>
    </test>
    </tests>
