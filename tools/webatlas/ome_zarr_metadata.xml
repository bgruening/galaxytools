<tool id="webatlas_ome_zarr_metadata" name="WebAtlas OME Zarr Metadata" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE_VERSION@">
    <description>extraction as JSON</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="requirements"/>
    <command detect_errors="exit_code"><![CDATA[
        ome_zarr_metadata.py --xml_path '$input_zarr.extra_files_path/$input_zarr.metadata.store_root/OME/METADATA.ome.xml' > output.json
    ]]></command>
    <inputs>
        <param name="input_zarr" type="data" format="zarr,ome_zarr" label="Zarr directory"/>
    </inputs>
    <outputs>
        <data name="output_json" format="json" label="${tool.name} on ${on_string}" from_work_dir="output.json"/>
    </outputs>
    <tests>
    <test expect_num_outputs="1">
        <param name="input_zarr" location="https://zenodo.org/records/19053876/files/visium-breast-cancer-label.zarr.zip"/>
        <output name="output_json">
            <assert_contents>
                <has_json_property_with_text property="dimOrder" text="XYZCT"/>
                <has_json_property_with_text property="X" text="19505"/>
                <has_json_property_with_text property="Y" text="21571"/>
                <has_json_property_with_text property="Z" text="1"/>
                <has_json_property_with_text property="C" text="1"/>
                <has_json_property_with_text property="T" text="1"/>
                <has_size value="101" delta="5"/>
            </assert_contents>
        </output>
    </test>
    <test expect_num_outputs="1">
        <param name="input_zarr" location="https://zenodo.org/records/19053876/files/visium-breast-cancer-raw.zarr.zip"/>
        <output name="output_json">
            <assert_contents>
                <has_json_property_with_text property="dimOrder" text="XYZCT"/>
                <has_json_property_with_text property="X" text="19505"/>
                <has_json_property_with_text property="Y" text="21571"/>
                <has_json_property_with_text property="Z" text="1"/>
                <has_json_property_with_text property="C" text="3"/>
                <has_json_property_with_text property="T" text="1"/>
                <has_size value="101" delta="5"/>
            </assert_contents>
        </output>
    </test>
    </tests>
    <help><![CDATA[
This tool extracts image metadata from a Zarr dataset containing OME metadata.

It is typically used on the output of **WebAtlas Consolidate Metadata** and provides metadata required for downstream visualization configuration.

----

**Input**

- **Zarr dataset (image)**
  generated by **WebAtlas Consolidate Metadata**

----

**Functionality**

The tool reads the OME XML metadata file stored within the Zarr dataset and extracts basic image metadata.

The extracted metadata includes:

- Dimension order (e.g. XYZCT)
- Image dimensions (X, Y, Z, C, T)
- Channel names

----

**Output**

- **Metadata (JSON)**

The output is used as input for the downstream WebAtlas tool **WebAtlas Build Vitessce Config**.
    ]]></help>
    <expand macro="citations"/>
</tool>