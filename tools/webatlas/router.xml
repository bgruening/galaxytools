        ## #elif $input_type_selector == 'molecules':
        ##     /usr/local/bin/process_molecules.py --path $input_molecules --stem $stem --has_header $has_header --gene_col_name $gene_col_name --x_col_name $x_col_name --y_col_name $y_col_name --delimiter $delimiter --x_scale $x_scale --y_scale $y_scale --x_offset $x_offset --y_offset $y_offset --gene_col_idx $gene_col_idx --x_col_idx $x_col_idx --y_col_idx $y_col_idx --filter_col_name $filter_col_name --filter_col_idx $filter_col_idx --filter_col_value $filter_col_value &&
        ##     mv '$stem'*.json $output_json
