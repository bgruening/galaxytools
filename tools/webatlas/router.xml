    ]]></command>
    <inputs>
        <conditional name="input_type">
            <param name="input_type_selector" type="select" label="Choose the type of input data" help="Choose the format of the input dataset to process into AnnData-Zarr.">
                <option value="h5ad">Input AnnData file (H5AD)</option>
                <option value="spaceranger">SpaceRanger output archive (ZIP)</option>
                <option value="xenium">Xenium output archive (ZIP)</option>
                <option value="merscope">MERSCOPE output archive (ZIP)</option>
                <!-- Currently there is no usecase for this option. It can be implemented on request -->
                <!-- <option value="molecules">Molecules data in csv/tsv file</option> -->
            </param>
            <when value="h5ad">
                <param name="input_h5ad" type="data" format="h5ad" label="Input AnnData file (H5AD)"/>
                <expand macro="stem"/>
                <expand macro="h5ad_to_zarr_parameters"/>
            </when>
            <when value="spaceranger">
                <param name="input_spaceranger" type="data" format="zip" label="SpaceRanger output archive (ZIP)"/>
                <expand macro="stem"/>
                <param argument="--load_clusters" type="boolean" checked="true" optional="true" label="Include cluster files" help="If cluster files should be included in the AnnData object."/>
                <param argument="--load_embeddings" type="boolean" checked="true" optional="true" label="Include embeddings" help="If embedding coordinates files should be included in the AnnData object."/>
                <param argument="--load_raw" type="boolean" checked="false" optional="true" label="Use raw matrix count file" help="If the raw matrix count file should be loaded instead of the filtered matrix."/>
                <expand macro="h5ad_to_zarr_parameters"/>
                <expand macro="save_h5ad"/>
            </when>
            <when value="xenium">
                <param name="input_xenium" type="data" format="zip" label="Xenium output archive (ZIP)"/>
                <expand macro="stem"/>
                <param argument="--spatial_as_pixel" type="boolean" checked="true" label="Convert spatial coordinates to pixel coordinates" help="Convert Xenium spatial coordinates to pixel coordinates using the specified resolution."/>
                <param argument="--resolution" type="float" value="0.2125" optional="true" label="Pixel resolution" help="Pixel resolution to use for converting spatial coordinates to pixel coordinates. Default value: 0.2125"/>
                <expand macro="h5ad_to_zarr_parameters"/>
                <expand macro="save_h5ad"/>
            </when>
            <when value="merscope">
                <param name="input_merscope" type="data" format="zip" label="MERSCOPE output archive (ZIP)"/>
                <expand macro="stem"/>
                <param argument="--filter_prefix" type="text" value="Blank-" optional="true" label="Filter prefix" help="Prefix to filter out of the data. Default value: 'Blank-'.">
                    <sanitizer invalid_char="">
                        <valid initial="string.ascii_letters,string.digits">
                            <add value="_"/>
                            <add value="-"/>
                            <add value="."/>
                        </valid>
                    </sanitizer>
                </param>
                <expand macro="h5ad_to_zarr_parameters"/>
                <expand macro="save_h5ad"/>
            </when>
            <!-- <when value="molecules">
                <param name="input_molecules" type="data" format="csv,tsv" label="Molecules file"/>
                <expand macro="stem"/>
                <param name="has_header" type="boolean" checked="true" optional="true" label="Does the input file contain a header row?"/>
                <param name="gene_col_name" type="text" value="Name" optional="true" label="Column header name where gene names are stored." help="Default value: Name"/>
                <param name="x_col_name" type="text" value="x_int" optional="true" label="Column header name where 'X' coordinates are stored." help="Default value: x_int"/>
                <param name="y_col_name" type="text" value="y_int" optional="true" label="Column header name where 'Y' coordinates are stored." help="Default value: y_int"/>
                <param name="delimiter" type="text" value="\t" optional="true" label="Input file delimiter." help="Default value: \t"/>
                <param name="x_scale" type="float" value="1.0" optional="true" label="Scale to multiply 'X' coordinates by." help="Default value: 1.0"/>
                <param name="y_scale" type="float" value="1.0" optional="true" label="Scale to multiply 'Y' coordinates by." help="Default value: 1.0"/>
                <param name="x_offset" type="float" value="0.0" optional="true" label="Offset to add to 'X' coordinates." help="Default value: 0.0"/>
                <param name="y_offset" type="float" value="0.0" optional="true" label="Offset to add to 'Y' coordinates." help="Default value: 0.0"/>
                <param name="gene_col_idx" type="integer" optional="true" label="Column index where gene names are stored if header is not present."/>
                <param name="x_col_idx" type="integer" optional="true" label="Column index where 'X' coordinates are stored if header is not present."/>
                <param name="y_col_idx" type="integer" optional="true" label="Column index where 'Y' coordinates are stored if header is not present." />
                <param name="filter_col_name" type="text" optional="true" label="Column header name storing values to filter data."/>
                <param name="filter_col_idx" type="integer" optional="true" label="Column index storing values to filter data if header is not present."/>
                <param name="filter_col_value" type="text" optional="true" label="Value expected in filter column. If a row has a different value it will not be written to the output file."/>
            </when> -->
        </conditional>
    </inputs>
    <outputs>
        <data name="output_h5ad" format="h5ad" label="${tool.name} on ${on_string}: H5AD output">
            <filter>'h5ad' not in input_type['input_type_selector'] and 'molecules' not in input_type['input_type_selector'] and input_type['save_h5ad']
            </filter>
        </data>
        <data name="output_zarr" format="zarr.zip" label="${tool.name} on ${on_string}: ZIP-compressed Zarr output">
            <filter>input_type['input_type_selector'] == 'h5ad' or input_type['input_type_selector'] == 'spaceranger' or input_type['input_type_selector'] == 'xenium' or input_type['input_type_selector'] == 'merscope'
            </filter>
        </data>
        <!-- <data name="output_json" format="json" label="${tool.name} on ${on_string}">
            <filter>input_type['input_type_selector'] == 'molecules'</filter>
        </data> -->
    </outputs>
    <tests>
    <test expect_num_outputs="1">
        <conditional name="input_type">
            <param name="input_type_selector" value="h5ad"/>
            <param name="input_h5ad" location="https://zenodo.org/records/19053876/files/input.h5ad"/>
            <param name="stem" value="h5ad"/>
            <param name="chunk_size" value="10"/>
            <param name="compute_embeddings" value="false"/>
            <section name="sec_advanced_options">
                <param name="var_index" value=""/>
                <conditional name="obs_subset_conditional">
                    <param name="obs_subset" value="false"/>
                </conditional>
                <conditional name="var_subset_conditional">
                    <param name="var_subset" value="false"/>
                </conditional>
                <conditional name="batch_processing_conditional">
                    <param name="batch_processing" value="false"/>
                </conditional>
            </section>
        </conditional>
        <output name="output_zarr">
            <assert_contents>
                <has_size value="78759191" delta="100"/>
            </assert_contents>
        </output>
    </test>

