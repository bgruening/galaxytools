<tool id="webatlas_router" name="WebAtlas Process Files" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" python_template_version="3.5" profile="@PROFILE_VERSION@">
    <description>Processes input into AnnData-Zarr</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="requirements"/>
    <command detect_errors="exit_code"><![CDATA[
        #if $input_type_selector == 'h5ad':
            ln -s '$input_h5ad' input.h5ad &&
            /usr/local/bin/process_h5ad.py --path input.h5ad --stem $stem
