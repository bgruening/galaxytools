                --resolution $resolution
            #end if
            #if $save_h5ad:
                --save_h5ad
            #end if
            @H5AD_TO_ZARR_COMMAND_BLOCK@
            #if $save_h5ad:
                mv tmp-'$stem'.h5ad $output_h5ad &&
            #end if
            zip -r $stem-anndata.zarr.zip $stem-anndata.zarr &&
            mv $stem-anndata.zarr.zip $output_zarr
        #elif $input_type_selector == 'merscope':
            mkdir unpacked_merscope &&
            unzip $input_merscope -d unpacked_merscope &&
            /usr/local/bin/process_merscope.py --path unpacked_merscope --stem $stem --filter_prefix $filter_prefix
            #if $save_h5ad:
