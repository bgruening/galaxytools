    <inputs>
        <conditional name="input_type">
            <param name="input_type_selector" type="select" label="Choose the type of input data" help="">
                <option value="h5ad">AnnData (h5ad file)</option>
                <option value="spaceranger">SpaceRanger output</option>
                <option value="xenium">Xenium output</option>
                <option value="merscope">MERSCOPE output</option>
                <!-- Currently there is no usecase for this option. It can be implemented on request -->
                <!-- <option value="molecules">Molecules data in csv/tsv file</option> -->
            </param>
            <when value="h5ad">
                <param name="input_h5ad" type="data" format="h5ad" label="h5ad file"/>
                <expand macro="stem"/>
                <expand macro="h5ad_to_zarr_parameters"/>
            </when>
            <when value="spaceranger">
                <param name="input_spaceranger" type="data" format="zip" label="Compressed SpaceRanger output"/>
                <expand macro="stem"/>
                <param name="load_clusters" type="boolean" label="Include cluster files" optional="true" checked="true" help="If cluster files should be included in the AnnData object."/>
                <param name="load_embeddings" type="boolean" label="Include embeddings" optional="true" checked="true" help="If embedding coordinates files should be included in the AnnData object."/>
                <param name="load_raw" type="boolean" label="Use raw matrix count file" optional="true" checked="false" help="If the raw matrix count file should be loaded instead of the filtered matrix."/>
                <expand macro="h5ad_to_zarr_parameters"/>
                <expand macro="save_h5ad"/>
            </when>
            <when value="xenium">
                <param name="input_xenium" type="data" format="zip" label="Compressed Xenium output"/>
                <expand macro="stem"/>
                <param name="spatial_as_pixel" type="boolean" label="Convert spatial coordinates to pixels" checked="true"/>
                <param name="resolution" type="float" label="Pixel resolution" optional="true" value="0.2125" help="Default value: 0.2125"/>
                <expand macro="h5ad_to_zarr_parameters"/>
                <expand macro="save_h5ad"/>
            </when>
            <when value="merscope">
                <param name="input_merscope" type="data" format="zip" label="Compressed MERSCOPE output"/>
                <expand macro="stem"/>
                <param name="filter_prefix" type="text" value="Blank-" label="Filter prefix" optional="true" help="Prefix to filter out of the data. Default value: Blank-"/>
                <expand macro="h5ad_to_zarr_parameters"/>
                <expand macro="save_h5ad"/>
            </when>
            <!-- <when value="molecules">
                <param name="input_molecules" type="data" format="csv,tsv" label="Molecules file"/>
                <expand macro="stem"/>
                <param name="has_header" type="boolean" label="Does the input file contain a header row?" optional="true" checked="true"/>
                <param name="gene_col_name" type="text" label="Column header name where gene names are stored." optional="true" value="Name" help="Default value: Name"/>
                <param name="x_col_name" type="text" label="Column header name where 'X' coordinates are stored." optional="true" value="x_int" help="Default value: x_int"/>
                <param name="y_col_name" type="text" label="Column header name where 'Y' coordinates are stored." optional="true" value="y_int" help="Default value: y_int"/>
                <param name="delimiter" type="text" label="Input file delimiter." optional="true" value="\t" help="Default value: \t"/>
                <param name="x_scale" type="float" label="Scale to multiply 'X' coordinates by." optional="true" value="1.0" help="Default value: 1.0"/>
                <param name="y_scale" type="float" label="Scale to multiply 'Y' coordinates by." optional="true" value="1.0" help="Default value: 1.0"/>
                <param name="x_offset" type="float" label="Offset to add to 'X' coordinates." optional="true" value="0.0" help="Default value: 0.0"/>
                <param name="y_offset" type="float" label="Offset to add to 'Y' coordinates." optional="true" value="0.0" help="Default value: 0.0"/>
                <param name="gene_col_idx" type="integer" label="Column index where gene names are stored if header is not present." optional="true"/>
                <param name="x_col_idx" type="integer" label="Column index where 'X' coordinates are stored if header is not present." optional="true"/>
                <param name="y_col_idx" type="integer" label="Column index where 'Y' coordinates are stored if header is not present." optional="true"/>
                <param name="filter_col_name" type="text" label="Column header name storing values to filter data." optional="true"/>
                <param name="filter_col_idx" type="integer" label="Column index storing values to filter data if header is not present." optional="true"/>
                <param name="filter_col_value" type="text" label="Value expected in filter column. If a row has a different value it will not be written to the output file." optional="true"/>
            </when> -->
        </conditional>
    </inputs>
    <outputs>
        <data name="output_h5ad" format="h5ad" label="${tool.name} on ${on_string}: h5ad output">
            <filter>'h5ad' not in input_type['input_type_selector'] and 'molecules' not in input_type['input_type_selector'] and input_type['save_h5ad']
            </filter>
        </data>
        <data name="output_zarr" format="zarr.zip" label="${tool.name} on ${on_string}: compressed zarr output">
            <filter>input_type['input_type_selector'] == 'h5ad' or input_type['input_type_selector'] == 'spaceranger' or input_type['input_type_selector'] == 'xenium' or input_type['input_type_selector'] == 'merscope'
            </filter>
        </data>
        <!-- <data name="output_json" format="json" label="${tool.name} on ${on_string}">
            <filter>input_type['input_type_selector'] == 'molecules'</filter>
        </data> -->
    </outputs>
    <tests>
    <test expect_num_outputs="1">
        <conditional name="input_type">
            <param name="input_type_selector" value="h5ad"/>
            <param name="input_h5ad" value="input.h5ad"/>
            <param name="stem" value="h5ad"/>
            <param name="chunk_size" value="10"/>
            <param name="compute_embeddings" value="false"/>
            <param name="var_index" value=""/>
            <conditional name="obs_subset_conditional">
                <param name="obs_subset" value="false"/>
            </conditional>
            <conditional name="var_subset_conditional">
                <param name="var_subset" value="false"/>
            </conditional>
            <conditional name="batch_processing_conditional">
                <param name="batch_processing" value="false"/>
            </conditional>
        </conditional>
        <output name="output_zarr">
            <assert_contents>
                <has_size value="78759191" delta="100"/>
            </assert_contents>
        </output>
    </test>

