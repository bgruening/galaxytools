<tool id="flexynesis_infer" name="Flexynesis Inference" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="@PROFILE@">
    <description>Run inference using a pretrained Flexynesis model</description>
    <macros>
        <import>macros.xml</import>
    </macros>
    <expand macro="edam"/>
    <expand macro="requirements"/>
    <required_files>
        <include path="flexynesis_utils.py" />
        <include path="convert.py" />
        <include path="artifacts_json.py" />
    </required_files>
    <command detect_errors="exit_code"><![CDATA[
        @CHECK_NON_COMMERCIAL_USE@
        export TORCHINDUCTOR_CACHE_DIR=/tmp/torch_cache &&
        mkdir -p input/test output &&


    ]]></command>
    <environment_variables>
        <!-- we will disable the progress bar which is printed to stderr -->
        <environment_variable name="TQDM_DISABLE">1</environment_variable>
    </environment_variables>
    <inputs>
        <expand macro="commercial_use_param"/>
        <expand macro="main_inputs"/>
        <param name="model" type="data" format="safetensors" label="Pretrained model"/>
        <param name="artifacts" type="data" format="json" label="Training artifacts"/>
        <repeat name="omics" min="0" title="Multiple omics layers?">
            <expand macro="extra_inputs"/>
        </repeat>
    </inputs>
    <outputs>
        <collection name="results" type="list" label="${tool.name} on ${on_string}: results">
            <discover_datasets pattern="(?P&lt;name&gt;.+)\.tabular$" format="tabular" directory="output"/>
        </collection>
    </outputs>
    <tests>
    </tests>
    <help><![CDATA[
@COMMON_HELP@

**Flexynesis Inference Mode**

This tool runs inference using a pretrained Flexynesis model on new test data, without retraining.

-----

**When to use inference mode**

Use this tool when you have:

1. A trained model from a previous Flexynesis training run
2. The corresponding artifacts file from that training run
3. New samples you want to classify/predict using the trained model

-----


.. _Documentation: https://bimsbstatic.mdc-berlin.de/akalin/buyar/flexynesis/site/
.. _copyright holders: https://github.com/BIMSBbioinfo/flexynesis
    ]]></help>
    <expand macro="creator"/>
    <expand macro="citations"/>
</tool>
